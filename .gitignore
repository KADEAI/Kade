# Logs
logs
*.log

# IDE specific files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS generated files
.Trash/
Thumbs.db

# Test coverage
coverage/
*.lcov

# Package managers
package-lock.json
yarn.lock
pnpm-lock.yaml

# Compiled output
*.js
*.map
*.d.ts

# Explicitly *not* ignore these directories
!src/
!webview-ui/

# Add any other extensive ignores here as needed

