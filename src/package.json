{
	"name": "kade",
	"displayName": "%extension.displayName%",
	"description": "%extension.description%",
	"publisher": "KADEAI",
	"version": "4.0.1",
	"repository": {
		"type": "git",
		"url": "https://github.com/KADEAI/Kade"
	},
	"icon": "assets/icons/logo.png",
	"galleryBanner": {
		"color": "#FFFFFF",
		"theme": "light"
	},
	"engines": {
		"vscode": "^1.84.0",
		"node": "20.19.2"
	},
	"extensionKind": [
		"workspace"
	],
	"capabilities": {
		"microphone": true
	},
	"author": {
		"name": "Kade"
	},
	"homepage": "https://kadei.org",
	"categories": [
		"AI",
		"Chat",
		"Programming Languages",
		"Education",
		"Snippets",
		"Testing"
	],
	"keywords": [
		"kade",
		"claude",
		"dev",
		"mcp",
		"openrouter",
		"coding",
		"agent",
		"autonomous",
		"chatgpt",
		"sonnet",
		"ai",
		"llama",
		"Kade",
		"kade"
	],
	"activationEvents": [
		"onLanguage",
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"walkthroughs": [
			{
				"id": "kadeWalkthrough",
				"title": "5 ways Kade helps you code",
				"description": "You now have a personal AI coding assistant.",
				"steps": [
					{
						"id": "welcome",
						"title": "Write code for you",
						"description": "Describe what you want to build. Kade will write it from scratch, generate the files, and run them for you.",
						"media": {
							"markdown": "./dist/walkthrough/step1.md"
						}
					},
					{
						"id": "getting-started",
						"title": "Understand your codebase",
						"description": "Need clarity on how something works? Ask Kade about any part of your files and get a clear explanation.",
						"media": {
							"markdown": "./dist/walkthrough/step2.md"
						},
						"content": {
							"path": "./dist/walkthrough/step2.md"
						}
					},
					{
						"id": "modes",
						"title": "Get things working again",
						"description": "Stuck on an error? Kade can find the issue, fix it, and get your code running.",
						"media": {
							"markdown": "./dist/walkthrough/step3.md"
						}
					},
					{
						"id": "code-actions",
						"title": "Plan your logic",
						"description": "Not sure where to start? Map out your logic and structure before writing a single line of code.",
						"media": {
							"markdown": "./dist/walkthrough/step4.md"
						}
					},
					{
						"id": "advanced-features",
						"title": "And more",
						"description": "Improve your prompt, add context, or create your own custom modes.",
						"media": {
							"markdown": "./dist/walkthrough/step5.md"
						}
					}
				]
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "kade-ActivityBar",
					"title": "%views.activitybar.title%",
					"icon": "assets/icons/sidebar-icon.png"
				}
			]
		},
		"views": {
			"kade-ActivityBar": [
				{
					"type": "webview",
					"id": "kade.SidebarProvider",
					"name": "%views.sidebar.name%",
					"icon": "assets/icons/sidebar-icon.png"
				}
			]
		},
		"commands": [
			{
				"command": "kade.plusButtonClicked",
				"title": "%command.newTask.title%",
				"icon": "$(add)"
			},
			{
				"command": "kade.sidebarPlusButtonClicked",
				"title": "%command.newTask.title%",
				"icon": "$(add)"
			},
			{
				"command": "kade.tabPlusButtonClicked",
				"title": "%command.newTask.title%",
				"icon": "$(add)"
			},
			{
				"command": "kade.mcpButtonClicked",
				"title": "%command.marketplace.title%",
				"icon": "$(extensions)"
			},
			{
				"command": "kade.sidebarMcpButtonClicked",
				"title": "%command.marketplace.title%",
				"icon": "$(extensions)"
			},
			{
				"command": "kade.tabMcpButtonClicked",
				"title": "%command.marketplace.title%",
				"icon": "$(extensions)"
			},
			{
				"command": "kade.importSettings",
				"title": "%command.importSettings.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.exportSettings",
				"title": "Export Settings",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.promptsButtonClicked",
				"title": "%command.prompts.title%",
				"icon": "$(organization)"
			},
			{
				"command": "kade.historyButtonClicked",
				"title": "%command.history.title%",
				"icon": "$(history)"
			},
			{
				"command": "kade.sidebarHistoryButtonClicked",
				"title": "%command.history.title%",
				"icon": "$(history)"
			},
			{
				"command": "kade.tabHistoryButtonClicked",
				"title": "%command.history.title%",
				"icon": "$(history)"
			},
			{
				"command": "kade.popoutButtonClicked",
				"title": "%command.openInEditor.title%",
				"icon": "$(link-external)"
			},
			{
				"command": "kade.sidebarPopoutButtonClicked",
				"title": "%command.openInEditor.title%",
				"icon": "$(link-external)"
			},
			{
				"command": "kade.tabPopoutButtonClicked",
				"title": "%command.openInEditor.title%",
				"icon": "$(link-external)"
			},
			{
				"command": "kade.settingsButtonClicked",
				"title": "%command.settings.title%",
				"icon": "$(settings-gear)"
			},
			{
				"command": "kade.sidebarSettingsButtonClicked",
				"title": "%command.settings.title%",
				"icon": "$(settings-gear)"
			},
			{
				"command": "kade.tabSettingsButtonClicked",
				"title": "%command.settings.title%",
				"icon": "$(settings-gear)"
			},
			{
				"command": "kade.helpButtonClicked",
				"title": "%command.documentation.title%",
				"icon": "$(question)"
			},
			{
				"command": "kade.sidebarHelpButtonClicked",
				"title": "%command.documentation.title%",
				"icon": "$(question)"
			},
			{
				"command": "kade.tabHelpButtonClicked",
				"title": "%command.documentation.title%",
				"icon": "$(question)"
			},
			{
				"command": "kade.openInNewTab",
				"title": "%command.openInNewTab.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.agentManagerOpen",
				"title": "%command.agentManager.title%",
				"icon": "$(comment-discussion)",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.explainCode",
				"title": "%command.explainCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.fixCode",
				"title": "%command.fixCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.improveCode",
				"title": "%command.improveCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.addToContext",
				"title": "%command.addToContext.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.addToContextAndFocus",
				"title": "Add to Context and Focus",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.newTask",
				"title": "%command.newTask.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.terminalAddToContext",
				"title": "%command.terminal.addToContext.title%",
				"category": "%extension.displayName%"
			},
			{
				"command": "kade.terminalFixCommand",
				"title": "%command.terminal.fixCommand.title%",
				"category": "%extension.displayName%"
			},
			{
				"command": "kade.terminalExplainCommand",
				"title": "%command.terminal.explainCommand.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.generateTerminalCommand",
				"title": "%command.terminal.generateCommand.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.setCustomStoragePath",
				"title": "%command.setCustomStoragePath.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.focusChatInput",
				"title": "%command.focusInput.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.acceptInput",
				"title": "%command.acceptInput.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.profileButtonClicked",
				"title": "%command.profile.title%",
				"icon": "$(account)",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.vsc.generateCommitMessage",
				"title": "%command.generateCommitMessage.title%",
				"icon": {
					"light": "assets/icons/kilo-light.svg",
					"dark": "assets/icons/kilo-dark.svg"
				},
				"category": "%configuration.title%"
			},
			{
				"command": "kade.ghost.generateSuggestions",
				"title": "%ghost.commands.generateSuggestions%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.ghost.cancelSuggestions",
				"title": "%ghost.commands.cancelSuggestions%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.ghost.applyCurrentSuggestions",
				"title": "%ghost.commands.applyCurrentSuggestion%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.ghost.applyAllSuggestions",
				"title": "%ghost.commands.applyAllSuggestions%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.ghost.goToNextSuggestion",
				"title": "%ghost.commands.goToNextSuggestion%",
				"category": "%configuration.title%"
			},
			{
				"command": "kade.ghost.goToPreviousSuggestion",
				"title": "%ghost.commands.goToPreviousSuggestion%",
				"category": "%configuration.title%"
			}
		],
		"menus": {
			"editor/context": [
				{
					"submenu": "kade.contextMenu",
					"group": "1"
				}
			],
			"kade.contextMenu": [
				{
					"command": "kade.explainCode",
					"group": "1_actions@1"
				},
				{
					"command": "kade.fixCode",
					"group": "1_actions@2"
				},
				{
					"command": "kade.improveCode",
					"group": "1_actions@3"
				},
				{
					"command": "kade.addToContext",
					"group": "1_actions@4"
				}
			],
			"terminal/context": [
				{
					"submenu": "kade.terminalMenu",
					"group": "2"
				}
			],
			"kade.terminalMenu": [
				{
					"command": "kade.terminalAddToContext",
					"group": "1_actions@1"
				},
				{
					"command": "kade.terminalFixCommand",
					"group": "1_actions@2"
				},
				{
					"command": "kade.terminalExplainCommand",
					"group": "1_actions@3"
				}
			],
			"view/title": [
				{
					"command": "kade.sidebarPlusButtonClicked",
					"group": "navigation@0",
					"when": "view == kade.SidebarProvider"
				},
				{
					"command": "kade.sidebarMcpButtonClicked",
					"group": "navigation@1",
					"when": "view == kade.SidebarProvider"
				},
				{
					"command": "kade.agentManagerOpen",
					"group": "navigation@2",
					"when": "view == kade.SidebarProvider"
				},
				{
					"command": "kade.sidebarHistoryButtonClicked",
					"group": "navigation@4",
					"when": "view == kade.SidebarProvider"
				},
				{
					"command": "kade.sidebarSettingsButtonClicked",
					"group": "navigation@6",
					"when": "view == kade.SidebarProvider"
				},
				{
					"command": "kade.sidebarPopoutButtonClicked",
					"group": "navigation@7",
					"when": "view == kade.SidebarProvider"
				},
				{
					"command": "kade.sidebarHelpButtonClicked",
					"group": "navigation@9",
					"when": "false && view == kade.SidebarProvider"
				}
			],
			"editor/title": [
				{
					"command": "kade.tabPlusButtonClicked",
					"group": "navigation@1",
					"when": "activeWebviewPanelId == kade.TabPanelProvider"
				},
				{
					"command": "kade.tabMcpButtonClicked",
					"group": "navigation@2",
					"when": "activeWebviewPanelId == kade.TabPanelProvider"
				},
				{
					"command": "kade.agentManagerOpen",
					"group": "navigation@3",
					"when": "activeWebviewPanelId == kade.TabPanelProvider"
				},
				{
					"command": "kade.tabHistoryButtonClicked",
					"group": "navigation@4",
					"when": "activeWebviewPanelId == kade.TabPanelProvider"
				},
				{
					"command": "kade.tabPopoutButtonClicked",
					"group": "navigation@5",
					"when": "activeWebviewPanelId == kade.TabPanelProvider"
				},
				{
					"command": "kade.tabSettingsButtonClicked",
					"group": "navigation@6",
					"when": "activeWebviewPanelId == kade.TabPanelProvider"
				},
				{
					"command": "kade.tabHelpButtonClicked",
					"group": "navigation@7",
					"when": "activeWebviewPanelId == kade.TabPanelProvider"
				}
			],
			"scm/input": [
				{
					"command": "kade.vsc.generateCommitMessage",
					"group": "navigation"
				}
			],
			"scm/title": [
				{
					"command": "kade.vsc.generateCommitMessage",
					"when": "scmProvider == git",
					"group": "navigation"
				}
			]
		},
		"keybindings": [
			{
				"command": "kade.focusChatInput",
				"key": "ctrl+shift+a",
				"mac": "cmd+shift+a",
				"when": "true"
			},
			{
				"command": "kade.ghost.cancelSuggestions",
				"key": "escape",
				"when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && kilocode.ghost.hasSuggestions"
			},
			{
				"command": "kade.ghost.generateSuggestions",
				"key": "ctrl+l",
				"mac": "cmd+l",
				"when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && kilocode.ghost.enableSmartInlineTaskKeybinding && !github.copilot.completions.enabled"
			},
			{
				"command": "kade.ghost.showIncompatibilityExtensionPopup",
				"key": "ctrl+l",
				"mac": "cmd+l",
				"when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && kilocode.ghost.enableSmartInlineTaskKeybinding && github.copilot.completions.enabled"
			},
			{
				"command": "kade.generateTerminalCommand",
				"key": "ctrl+shift+g",
				"mac": "cmd+shift+g"
			},
			{
				"command": "kade.addToContext",
				"key": "cmd+k cmd+a",
				"mac": "cmd+k cmd+a",
				"win": "ctrl+k ctrl+a",
				"linux": "ctrl+k ctrl+a",
				"when": "editorTextFocus && editorHasSelection"
			},
			{
				"command": "kade.addToContextAndFocus",
				"key": "ctrl+i",
				"mac": "cmd+i",
				"win": "ctrl+i",
				"linux": "ctrl+i",
				"when": "editorTextFocus && !github.copilot.completions.enabled && kilocode.ghost.enableQuickInlineTaskKeybinding"
			},
			{
				"command": "kade.ghost.showIncompatibilityExtensionPopup",
				"key": "ctrl+i",
				"mac": "cmd+i",
				"when": "editorTextFocus && github.copilot.completions.enabled && kilocode.ghost.enableQuickInlineTaskKeybinding"
			},
			{
				"command": "kade.toggleAutoApprove",
				"key": "cmd+alt+a",
				"mac": "cmd+alt+a",
				"win": "ctrl+alt+a",
				"linux": "ctrl+alt+a"
			}
		],
		"submenus": [
			{
				"id": "kade.contextMenu",
				"label": "%views.contextMenu.label%"
			},
			{
				"id": "kade.terminalMenu",
				"label": "%views.terminalMenu.label%"
			}
		],
		"configuration": {
			"title": "%configuration.title%",
			"properties": {
				"kade.allowedCommands": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [
						"git log",
						"git diff",
						"git show",
						"*"
					],
					"description": "%commands.allowedCommands.description%"
				},
				"kade.deniedCommands": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "%commands.deniedCommands.description%"
				},
				"kade.commandExecutionTimeout": {
					"type": "number",
					"default": 0,
					"minimum": 0,
					"maximum": 600,
					"description": "%commands.commandExecutionTimeout.description%"
				},
				"kade.commandTimeoutAllowlist": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "%commands.commandTimeoutAllowlist.description%"
				},
				"kade.preventCompletionWithOpenTodos": {
					"type": "boolean",
					"default": false,
					"description": "%commands.preventCompletionWithOpenTodos.description%"
				},
				"kade.vsCodeLmModelSelector": {
					"type": "object",
					"properties": {
						"vendor": {
							"type": "string",
							"description": "%settings.vsCodeLmModelSelector.vendor.description%"
						},
						"family": {
							"type": "string",
							"description": "%settings.vsCodeLmModelSelector.family.description%"
						}
					},
					"description": "%settings.vsCodeLmModelSelector.description%"
				},
				"kade.customStoragePath": {
					"type": "string",
					"default": "",
					"description": "%settings.customStoragePath.description%"
				},
				"kade.enableCodeActions": {
					"type": "boolean",
					"default": true,
					"description": "%settings.enableCodeActions.description%"
				},
				"kade.autoImportSettingsPath": {
					"type": "string",
					"default": "",
					"description": "%settings.autoImportSettingsPath.description%"
				},
				"kade.maximumIndexedFilesForFileSearch": {
					"type": "number",
					"default": 10000,
					"minimum": 5000,
					"maximum": 500000,
					"description": "%settings.maximumIndexedFilesForFileSearch.description%"
				},
				"kade.useAgentRules": {
					"type": "boolean",
					"default": true,
					"description": "%settings.useAgentRules.description%"
				},
				"kade.apiRequestTimeout": {
					"type": "number",
					"default": 600,
					"minimum": 0,
					"maximum": 86400,
					"description": "%settings.apiRequestTimeout.description%"
				},
				"kade.newTaskRequireTodos": {
					"type": "boolean",
					"default": false,
					"description": "%settings.newTaskRequireTodos.description%"
				},
				"kade.enableSettingsSync": {
					"type": "boolean",
					"default": true,
					"description": "%settings.enableSettingsSync.description%"
				},
				"kade.codeIndex.embeddingBatchSize": {
					"type": "number",
					"default": 60,
					"minimum": 1,
					"maximum": 200,
					"description": "%settings.codeIndex.embeddingBatchSize.description%"
				},
				"kade.toolProtocol": {
					"type": "string",
					"enum": [
						"unified"
					],
					"default": "unified",
					"description": "%settings.toolProtocol.description%"
				},
				"kade.unifiedFormatVariant": {
					"type": "string",
					"enum": [
						"simple",
						"structured"
					],
					"default": "structured",
					"description": "%settings.unifiedFormatVariant.description%"
				},
				"kade.debug": {
					"type": "boolean",
					"default": false,
					"description": "%settings.debug.description%"
				}
			}
		},
		"icons": {
			"kilo-logo": {
				"description": "Kade logo",
				"default": {
					"fontPath": "assets/icons/kilo-icon-font.woff2",
					"fontCharacter": "\\F101"
				}
			}
		},
		"codeActions": [
			{
				"languages": [
					"*"
				],
				"providedCodeActionKinds": [
					"vscode.CodeActionKind.QuickFix"
				]
			}
		]
	},
	"scripts": {
		"lint": "eslint . --ext=ts --max-warnings=0",
		"check-types": "tsc --noEmit",
		"pretest": "turbo run kilo-code#bundle --cwd ..",
		"test": "vitest run",
		"format": "prettier --write .",
		"bundle": "node esbuild.mjs",
		"bundle:vsix": "pnpm bundle --production",
		"vscode:prepublish": "pnpm bundle --production",
		"vsix:clean": "rimraf ../bin",
		"vsix": "mkdirp ../bin && vsce package --no-dependencies --out ../bin",
		"vsix:unpacked": "mkdirp ../bin-unpacked && unzip -q -o ../bin/kilo-code-*.vsix -d ../bin-unpacked",
		"publish:marketplace": "vsce publish --no-dependencies && ovsx publish --no-dependencies",
		"watch:bundle": "pnpm bundle --watch",
		"watch:tsc": "cd .. && tsc --noEmit --watch --project src/tsconfig.json",
		"clean": "rimraf README.md CHANGELOG.md LICENSE dist logs mock .turbo"
	},
	"dependencies": {
		"@actions/core": "1.11.1",
		"@actions/github": "6.0.1",
		"@agentclientprotocol/sdk": "0.5.1",
		"@ai-sdk/amazon-bedrock": "3.0.73",
		"@ai-sdk/anthropic": "^3.0.12",
		"@ai-sdk/azure": "2.0.91",
		"@ai-sdk/cerebras": "1.0.34",
		"@ai-sdk/cohere": "2.0.22",
		"@ai-sdk/deepinfra": "1.0.31",
		"@ai-sdk/gateway": "2.0.25",
		"@ai-sdk/google": "^3.0.7",
